{
  "name": "woli-pixel-api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "bun run src/db/seed.ts",
    "db:studio": "drizzle-kit studio",
    "test": "bun test --cwd . src/",
    "test:watch": "bun test --cwd . --watch src/",
    "test:coverage": "bun test --cwd . --coverage src/"
  },
  "dependencies": {
    "hono": "^4.7.0",
    "drizzle-orm": "^0.40.0",
    "postgres": "^3.4.0",
    "sharp": "^0.33.0",
    "zod": "^3.24.0",
    "openai": "^5.0.0",
    "@anthropic-ai/sdk": "^0.39.0",
    "dotenv": "^16.4.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.3",
    "@types/bun": "latest",
    "drizzle-kit": "^0.30.0",
    "typescript": "^5.7.0"
  }
}
