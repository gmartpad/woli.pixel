# Banco de Dados
POSTGRES_USER=woli
POSTGRES_PASSWORD=change_me
POSTGRES_DB=woli_pixel
DATABASE_URL=postgresql://woli:change_me@localhost:5432/woli_pixel

# OpenAI (obrigatório)
OPENAI_API_KEY=sk-proj-...

# Anthropic (fallback, opcional)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Servidor
PORT=3000
NODE_ENV=development
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# AWS S3
AWS_REGION=sa-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
S3_BUCKET=woli-pixel-uploads
# AWS_ENDPOINT_URL=http://localhost:4566    # Optional: LocalStack for local dev

# CORS / Trusted Origins (production)
CORS_ORIGIN=http://localhost:5173
TRUSTED_ORIGINS=http://localhost:5173

# Frontend
VITE_API_URL=http://localhost:3000/api/v1

# Auth (better-auth)
BETTER_AUTH_SECRET=change_me_run_npx_auth_secret
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Resend (email)
RESEND_API_KEY=re_change_me
RESEND_FROM_EMAIL=noreply@yourdomain.com
